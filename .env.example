# Flask 配置
SECRET_KEY=your-secret-key-here

# AI 模型 API 配置
# 支持多种模型提供商：Anthropic Claude、阿里云百炼、OpenAI 等

# Anthropic Claude 配置
# AI_API_KEY=sk-ant-xxx
# AI_API_BASE_URL=https://api.anthropic.com/v1
# AI_MODEL=claude-sonnet-4-20250514

# 阿里云百炼配置（通义千问）
# AI_API_KEY=sk-xxx
# AI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_MODEL=qwen-plus

# OpenAI 配置
# AI_API_KEY=sk-xxx
# AI_API_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# 自定义 API 配置（OpenAI 兼容格式）
AI_API_KEY=your-api-key-here
AI_API_BASE_URL=your-base-url-here
AI_MODEL=your-model-name-here
